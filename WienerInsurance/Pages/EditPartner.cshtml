@page "{id:int}"
@model WienerInsurance.Pages.EditPartnerModel
@{
    ViewData["Title"] = "Uredi partnera";
}

<div class="container-fluid mt-4 px-md-5">
    <h2 class="text-secondary font-weight-bold mb-4">Uređivanje partnera</h2>
    <form method="post" class="needs-validation" novalidate>
        @* <input type="hidden" asp-for="Input.Id" /> *@

        @{
            ViewData.TemplateInfo.HtmlFieldPrefix = nameof(Model.Input);
        }

        <partial name="_PartnerForm" model="Model.Input" />

        <div class="d-flex justify-content-between border-top pt-3 mt-4">
            <a asp-page="/Index" class="btn btn-outline-secondary px-4">Odustani</a>
            <button type="submit" class="btn btn-primary px-5 font-weight-bold">Spremi izmjene</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}