@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@model WienerInsurance.Pages.IndexModel
@{
    ViewData["Title"] = "Popis Partnera";
}

<div class="container-fluid mt-4 px-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Popis partnera</h2>
        <a asp-page="/CreatePartner" class="btn btn-primary shadow-sm">Dodaj novog partnera</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-4">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-4">@TempData["Error"]</div>
    }

    <div class="card bg-light mb-4 shadow-sm border-0">
        <div class="card-body py-3">
            <form method="get" class="font-weight-bold small">
                <div class="row g-2 mb-3">
                    <div class="col-md-3">
                        <label for="SearchPartnerNumber" class="form-label text-secondary mb-1">Broj partnera:</label>
                        <input type="text" asp-for="SearchPartnerNumber" class="form-control form-control-sm" placeholder="Broj partnera..." maxlength="20" />
                    </div>
                    <div class="col-md-3">
                        <label for="SearchName" class="form-label text-secondary mb-1">Pretraga po imenu:</label>
                        <input type="text" asp-for="SearchName" class="form-control form-control-sm" placeholder="Ime ili prezime..." />
                    </div>
                    <div class="col-md-2">
                        <label for="SearchOib" class="form-label text-secondary mb-1">OIB:</label>
                        <input type="text" asp-for="SearchOib" class="form-control form-control-sm" placeholder="OIB..." maxlength="11" />
                    </div>
                    <div class="col-md-2">
                        <label for="PartnerType" class="form-label text-secondary mb-1">Tip partnera:</label>
                        <select asp-for="PartnerType" class="form-control form-control-sm">
                            <option value="0">-- Svi --</option>
                            @foreach (var type in Model.PartnerTypes)
                            {
                                <option value="@type.Id">@type.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="StatusFilter" class="form-label text-secondary mb-1">Status:</label>
                        <select asp-for="StatusFilter" class="form-control form-control-sm">
                            <option value="active">Aktivni</option>
                            <option value="all">Sve</option>
                            <option value="inactive">Neaktivni</option>
                        </select>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12 d-flex justify-content-end align-items-center">
                        <button type="submit" class="btn btn-dark shadow-sm font-weight-bold px-4" style="min-width: 120px;">Traži</button>
                        <a asp-page="/Index" class="btn btn-outline-danger shadow-sm font-weight-bold px-4" style="min-width: 120px; margin-left: 15px;">Očisti</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover border">
            <thead class="thead-dark">
                <tr>
                    <th>Broj partnera</th>
                    <th>Puno ime</th>
                    <th>OIB</th>
                    <th>Tip partnera</th>
                    <th>Vrijeme kreiranja</th>
                    <th>Strani partner</th>
                    <th>Spol</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Partners.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">Nema pronađenih partnera za zadane kriterije.</td>
                    </tr>
                }
                @foreach (var p in Model.Partners)
                {
                    var isNew = Model.NewPartnerId != null && Model.NewPartnerId == p.Id;
                    var isUpdated = Model.UpdatedPartnerId != null && Model.UpdatedPartnerId == p.Id;

                    <tr id="partner-row-@p.Id" class="@(isNew ? "table-success font-weight-bold" : "") @(isUpdated ? "table-info font-weight-bold" : "")" style="cursor:pointer;" onclick="openDetailsModal(@p.Id, event)">
                        <td>
                            @p.PartnerNumber
                            @if (!p.IsActive)
                            {
                                <span class="badge bg-danger ms-2">Neaktivan</span>
                            }
                        </td>
                        <td>@p.FullName</td>
                        <td>@p.CroatianPIN</td>
                        <td>@p.PartnerTypeName</td>
                        <td>@p.CreatedAtFormatted</td>
                        <td>@(p.IsForeign ? "Da" : "Ne")</td>
                        <td>@p.GenderName</td>
                        <td>
                            @if (p.IsActive)
                            {
                                <button type="button" class="btn btn-sm btn-outline-success" onclick="openPolicyModal(@p.Id); event.stopPropagation();">Unos police</button>
                                <a asp-page="/EditPartner" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation();">Uredi</a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@p.Id" style="display:inline-block;" onsubmit="event.stopPropagation(); return confirm('Jeste li sigurni da želite obrisati partnera?');">
                                    <input type="hidden" asp-for="StatusFilter" />
                                    <input type="hidden" asp-for="SearchName" />
                                    <input type="hidden" asp-for="SearchOib" />
                                    <input type="hidden" asp-for="SearchPartnerNumber" />
                                    <input type="hidden" asp-for="PartnerType" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Obriši</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Restore" asp-route-id="@p.Id" style="display:inline-block;" onsubmit="event.stopPropagation(); return confirm('Jeste li sigurni da želite aktivirati partnera?');">
                                    <input type="hidden" asp-for="StatusFilter" />
                                    <input type="hidden" asp-for="SearchName" />
                                    <input type="hidden" asp-for="SearchOib" />
                                    <input type="hidden" asp-for="SearchPartnerNumber" />
                                    <input type="hidden" asp-for="PartnerType" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Aktiviraj</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="detailsModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-info text-white d-flex justify-content-between align-items-center">
                <h5 class="modal-title mb-0">Detalji partnera <span id="detStatus"></span></h5>
                <button type="button" id="closeDetailsBtn" class="close text-white ml-auto" data-dismiss="modal" aria-label="Zatvori" style="font-size: 1.5rem; background: none; border: none; opacity: 0.8; cursor: pointer;">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <table class="table table-sm table-borderless mb-0">
                    <tr><th style="width:40%;">Puno ime:</th><td id="detFullName"></td></tr>
                    <tr><th>Adresa:</th><td id="detAddress"></td></tr>
                    <tr><th>Broj partnera:</th><td id="detPartnerNumber"></td></tr>
                    <tr><th>OIB:</th><td id="detOib"></td></tr>
                    <tr><th>Tip partnera:</th><td id="detType"></td></tr>
                    <tr><th>Kreiran:</th><td id="detCreatedAt"></td></tr>
                    <tr><th>Kreirao korisnik:</th><td id="detUser"></td></tr>
                    <tr><th>Strani partner:</th><td id="detIsForeign"></td></tr>
                    <tr><th>Vanjska šifra:</th><td id="detExtCode"></td></tr>
                    <tr><th>Spol:</th><td id="detGender"></td></tr>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="policyModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Unos nove police</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body" id="policyModalBody"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openPolicyModal(partnerId) {
            $.get(`/CreatePolicy?partnerId=${partnerId}`, function(data) {
                $('#policyModalBody').html(data);
                $('#policyModal').modal('show');
            });
        }
        $(document).on('submit', '#policyModalBody form', function(e) {
            e.preventDefault();
            var form = $(this);
            $.post(form.attr('action'), form.serialize(), function(res) {
                if(res.success) { 
                    $('#policyModal').modal('hide'); 
                    window.location.href = res.redirectUrl;
                }
                else { $('#policyModalBody').html(res); }
            });
        });

        function openDetailsModal(id, event) {
            if (event.target.tagName === 'A' || event.target.tagName === 'BUTTON') return;
            $.get(`?handler=Details&id=${id}`, function(data) {
                $('#detFullName').text(data.fullName); 
                $('#detAddress').text(data.address);
                $('#detPartnerNumber').text(data.partnerNumber); 
                $('#detOib').text(data.croatianPIN);
                $('#detType').text(data.partnerTypeName); 
                $('#detCreatedAt').text(data.createdAtFormatted);
                $('#detUser').text(data.createdByUserEmail || '-');
                $('#detIsForeign').text(data.isForeign ? 'Da' : 'Ne');
                $('#detExtCode').text(data.externalCode);
                $('#detGender').text(data.genderName);
                $('#detStatus').html(data.isActive === false 
                    ? '<span class="badge bg-danger ms-2">Neaktivan</span>' 
                    : '');
                $('#detailsModal').modal('show');
            });
        }
        $(document).ready(function() {
            $(document).on('click', '#closeDetailsBtn', function(e) {
                e.preventDefault();
                $('#detailsModal').modal('hide');
            });
        });

        // Auto-hide top alerts after 5 seconds
        $(function() {
            var alerts = $('.container-fluid .alert');
            if (alerts.length) {
                setTimeout(function() {
                    alerts.fadeOut(500, function() { $(this).remove(); });
                }, 5000);
            }
        });
    </script>
}