@page
@model WienerInsurance.Pages.ShowPoliciesModel
@{
    ViewData["Title"] = "Popis polica";
}

<div class="container-fluid mt-4 px-md-5">

    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="text-secondary font-weight-bold">Popis svih polica</h2>
    </div>

    <!-- Filtri -->
    <div class="card bg-light mb-4 shadow-sm border-0">
        <div class="card-body py-3">
            <form method="get" class="row g-3 align-items-end font-weight-bold small">

                <div class="col-md-4">
                    <label for="SelectedPartnerId" class="form-label text-secondary mb-1">Pretraga po partneru:</label>
                    <select asp-for="SelectedPartnerId" class="form-control select2" style="width: 100%;">
                        <option value="">-- Svi partneri --</option>
                        @foreach (var p in Model.AllPartners)
                        {
                            <option value="@p.Id">@p.PartnerNumber - @p.FullName</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label for="SearchPolicyNumber" class="form-label text-secondary mb-1">Broj police:</label>
                    <input type="text" asp-for="SearchPolicyNumber" class="form-control form-control-sm" placeholder="Upišite broj police..." />
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-dark btn-sm flex-fill shadow-sm font-weight-bold">Traži</button>
                    <a asp-page="/ShowPolicies" class="btn btn-outline-danger btn-sm flex-fill shadow-sm font-weight-bold">Očisti</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Tablica -->
    <div class="table-responsive">
        <table class="table table-hover border">
            <thead class="thead-dark">
                <tr>
                    <th>Partner</th>
                    <th>Broj police</th>
                    <th>Iznos police (€)</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Policies.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">Nema pronađenih polica.</td>
                    </tr>
                }
                else
                {
                    @foreach (var p in Model.Policies)
                    {
                        <tr>
                            <td>@p.PartnerFullName</td>
                            <td>@p.PolicyNumber</td>
                            <td>@p.Amount.ToString("N2") €</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function() {
        $('.select2').select2({
        placeholder: "Pretraži partnere...",
        allowClear: true
        });
        });
    </script>
}