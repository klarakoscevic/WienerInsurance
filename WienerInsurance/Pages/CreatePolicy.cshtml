@page
@model WienerInsurance.Pages.CreatePolicyModel
@{
    Layout = null;
}

<div class="container-fluid">
    <div class="mb-4 border-bottom pb-3">
        <h5 class="text-secondary font-weight-bold">Unos nove police</h5>
        <div class="text-muted small mt-1">
            Kreirate policu za partnera: <strong class="text-dark">@Model.PartnerFullName</strong> (@Model.PartnerNumber)
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mb-4">@Model.ErrorMessage</div>
    }

    <form method="post" asp-page="/CreatePolicy" class="needs-validation" novalidate>
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <input type="hidden" asp-for="Policy.PartnerId" />

        <div class="row">
            <div class="col-md-6 form-group mb-3">
                <label asp-for="Policy.PolicyNumber" class="font-weight-bold text-muted small">Broj police *</label>
                <input asp-for="Policy.PolicyNumber" class="form-control" required minlength="10" maxlength="15" placeholder="Npr. POL-12345678" />
                <div class="invalid-feedback">Broj police (10-15 znakova) je obavezan.</div>
            </div>

            <div class="col-md-6 form-group mb-3">
                <label asp-for="Policy.Amount" class="font-weight-bold text-muted small">Iznos police (€) *</label>
                <input asp-for="Policy.Amount" class="form-control" type="number" step="0.01" min="0.01" required placeholder="0.00" />
                <div class="invalid-feedback">Iznos mora biti veći od 0.</div>
            </div>
        </div>

        <div class="d-flex justify-content-end border-top pt-3 mt-4">
            <button type="button" class="btn btn-outline-secondary px-4 mr-2" data-dismiss="modal">Odustani</button>
            <button type="submit" class="btn btn-primary px-4 font-weight-bold">Spremi policu</button>
        </div>
    </form>
</div>

<script>
    (function() {
        var forms = document.getElementsByClassName('needs-validation');
        Array.prototype.filter.call(forms, function(form) {
            form.addEventListener('submit', function(event) {
                if (form.checkValidity() === false) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });
    })();
</script>