@page
@model WienerInsurance.Pages.Account.ShowUsersModel
@{
    ViewData["Title"] = "Popis korisnika";
}

<div class="container-fluid mt-4 px-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Popis korisnika</h2>
        <a asp-page="/Account/CreateUser" class="btn btn-primary shadow-sm">Dodaj novog korisnika</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-4">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-4">@TempData["Error"]</div>
    }

    <div class="card bg-light mb-4 shadow-sm border-0">
        <div class="card-body py-3">
            <form method="get" class="font-weight-bold small">
                <div class="row g-2 mb-3">
                    <div class="col-md-3">
                        <label for="SearchName" class="form-label text-secondary mb-1">Pretraga po imenu:</label>
                        <input type="text" asp-for="SearchName" class="form-control form-control-sm" placeholder="Ime ili prezime..." />
                    </div>
                    <div class="col-md-3">
                        <label for="RoleId" class="form-label text-secondary mb-1">Tip role:</label>
                        <select asp-for="RoleId" class="form-control form-control-sm">
                            <option value="0">-- Svi --</option>
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role.Id">@role.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="StatusFilter" class="form-label text-secondary mb-1">Status:</label>
                        <select asp-for="StatusFilter" class="form-control form-control-sm">
                            <option value="active">Aktivni</option>
                            <option value="inactive">Neaktivni</option>
                            <option value="all">Svi</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12 d-flex justify-content-end align-items-center">
                        <button type="submit" class="btn btn-dark shadow-sm font-weight-bold px-4" style="min-width: 120px;">
                            Traži
                        </button>
                        <a asp-page="/Account/ShowUsers" class="btn btn-outline-danger shadow-sm font-weight-bold px-4" style="min-width: 120px; margin-left: 15px;">
                            Očisti
                        </a>
                    </div>
                </div>

            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover border">
            <thead class="thead-dark">
                <tr>
                    <th>Ime i prezime</th>
                    <th>Email</th>
                    <th>Rola</th>
                    <th class="text-end">Akcije</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users == null || !Model.Users.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">Nema pronađenih korisnika.</td>
                    </tr>
                }
                else
                {
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>
                                @u.FullName
                                @if (!u.IsActive)
                                {
                                    <span class="badge bg-danger ms-2">Neaktivan</span>
                                }
                            </td>
                            <td>@u.Email</td>
                            <td>@u.RoleName</td>
                            <td class="text-end">
                                @if (u.IsActive)
                                {
                                    <a asp-page="/Account/EditUser" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Uredi</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@u.Id" class="d-inline" onsubmit="return confirm('Jeste li sigurni da želite obrisati korisnika?');">
                                        <input type="hidden" asp-for="RoleId" />
                                        <input type="hidden" asp-for="StatusFilter" />
                                        <input type="hidden" asp-for="SearchName" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger ms-2">Obriši</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Restore" asp-route-id="@u.Id" class="d-inline" onsubmit="return confirm('Jeste li sigurni da želite aktivirati korisnika?');">
                                        <input type="hidden" asp-for="RoleId" />
                                        <input type="hidden" asp-for="StatusFilter" />
                                        <input type="hidden" asp-for="SearchName" />
                                        <button type="submit" class="btn btn-sm btn-outline-success ms-2">Aktiviraj</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-hide top alerts after 5 seconds
        $(function() {
            var alerts = $('.container-fluid .alert');
            if (alerts.length) {
                setTimeout(function() {
                    alerts.fadeOut(500, function() { $(this).remove(); });
                }, 5000);
            }
        });
    </script>
}