@page
@model WienerInsurance.Pages.Account.CreateUserModel
@{
    ViewData["Title"] = "Dodaj korisnika";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="text-secondary font-weight-bold mb-4 text-center">Dodavanje novog korisnika</h2>

                    <form method="post" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label asp-for="FirstName" class="font-weight-bold text-muted small">Ime</label>
                                <input asp-for="FirstName" class="form-control" placeholder="Upišite ime..." />
                                <span asp-validation-for="FirstName" class="text-danger small d-block"></span>
                            </div>
                            <div class="col-md-6 form-group">
                                <label asp-for="LastName" class="font-weight-bold text-muted small">Prezime</label>
                                <input asp-for="LastName" class="form-control" placeholder="Upišite prezime..." />
                                <span asp-validation-for="LastName" class="text-danger small d-block"></span>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Email" class="font-weight-bold text-muted small">Email adresa</label>
                            <input asp-for="Email" class="form-control" placeholder="primjer@wiener.hr" />
                            <span asp-validation-for="Email" class="text-danger small d-block"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Password" class="font-weight-bold text-muted small">Privremena lozinka</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Upišite lozinku..." />
                            <span asp-validation-for="Password" class="text-danger small d-block"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="RoleId" class="font-weight-bold text-muted small">Uloga / Rola</label>
                            <select asp-for="RoleId" class="form-control">
                                <option value="0">-- Odaberite rolu --</option>
                                @if (Model.Roles != null)
                                {
                                    foreach (var r in Model.Roles)
                                    {
                                        <option value="@r.Id">@r.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="RoleId" class="text-danger small d-block"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-block font-weight-bold shadow-sm mb-2">Kreiraj korisnika</button>
                        <a asp-page="/Account/ShowUsers" class="btn btn-outline-secondary btn-block font-weight-bold">Odustani</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}